{
  "name": "primeteam-ops-cli",
  "version": "1.2.0-dev",
  "description": "CLI do squad primeteam-ops: opere a plataforma PrimeTeam via Claude Code com um único comando diário.",
  "private": true,
  "type": "module",
  "bin": {
    "pto": "./dist/index.js"
  },
  "files": [
    "dist",
    "cli/postinstall.mjs"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "tsx cli/index.ts",
    "start": "tsx cli/index.ts start",
    "setup": "tsx cli/index.ts setup",
    "login": "tsx cli/index.ts login",
    "whoami": "tsx cli/index.ts whoami",
    "logout": "tsx cli/index.ts logout",
    "refresh": "tsx cli/index.ts refresh",
    "doctor": "tsx cli/index.ts doctor",
    "update": "tsx cli/index.ts update",
    "cli": "tsx cli/index.ts",
    "postinstall": "node cli/postinstall.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@supabase/supabase-js": "^2.45.0",
    "boxen": "^7.1.1",
    "commander": "^12.1.0",
    "env-paths": "^3.0.0",
    "i18next": "^26.0.6",
    "i18next-fs-backend": "^2.6.4",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
