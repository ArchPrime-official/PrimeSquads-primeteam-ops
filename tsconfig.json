{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "cli",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["cli/**/*.ts"],
  "exclude": ["cli/**/*.mjs", "node_modules", "dist"]
}
